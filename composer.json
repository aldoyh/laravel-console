{
    "name": "redberry/laravel-console",
    "description": "Laravel Console is a convenient way to watch application logs in your browser's DevTools panel.",
    "type": "library",
    "authors": [
        {
            "name": "giunashvili",
            "email": "giuna@redberry.ge"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0",
        "illuminate/routing": "^12.0",
        "illuminate/cache": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "Redberry\\LaravelConsole\\": "/"
        },
        "files": [
            "./helpers.php"
        ]
    },
    "extra": {
        "laravel": {
            "providers": [
                "Redberry\\LaravelConsole\\ServiceProvider"
            ],
            "aliases": {
                "Console": "Redberry\\LaravelConsole\\Facades\\Console"
            }
        }
    },
    "license": "MIT"
}
